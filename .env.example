# Required — GHL Private Integration token
# GHL Settings → Integrations → Private Integrations → create/copy token
GHL_API_KEY=your_private_integration_token_here

# Required — GHL Sub-account Location ID
# GHL Settings → Business Info → Location ID
GHL_LOCATION_ID=your_location_id_here

# Optional — Custom field IDs for buyer price and list price columns
# If blank, the API will auto-detect by field name (looks for "assign/buyer" and "dispo/list")
# To find field IDs: GHL Settings → Custom Fields → click field → copy ID from URL
GHL_BUYER_PRICE_FIELD_ID=
GHL_LIST_PRICE_FIELD_ID=
