# Required — GHL Private Integration token
# GHL Settings → Integrations → Private Integrations → create/copy token
GHL_API_KEY=your_private_integration_token_here

# Required — GHL Sub-account Location ID
# GHL Settings → Business Info → Location ID
GHL_LOCATION_ID=your_location_id_here

# Optional — Custom field IDs for buyer price and list price columns
# If blank, the API will auto-detect by field name (looks for "assign/buyer" and "dispo/list")
# To find field IDs: GHL Settings → Custom Fields → click field → copy ID from URL
GHL_BUYER_PRICE_FIELD_ID=
GHL_LIST_PRICE_FIELD_ID=

# ── GHL Call Webhook (api/ghl-call-webhook.ts) ────────────────────────────────
# Required — Supabase project URL
# Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://xxxx.supabase.co

# Required — Supabase service role key (NOT the anon key — bypasses RLS)
# Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Required — Shared secret for webhook authentication
# Set this to whatever secret string you chose, then add it as a custom header
# in GHL: Settings → Integrations → Webhooks → your webhook → Header: x-ghl-secret
GHL_WEBHOOK_SECRET=your_webhook_secret_here
